{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Test mdx-tsc extension (playground)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode",
        "${workspaceFolder}/playground"
      ],
      "outFiles": ["${workspaceFolder}/editors/vscode/dist/**/*.js"],
      "preLaunchTask": "mdx-tsc: build all"
    }
  ]
}
