{
  "name": "mdx-tsc-vscode",
  "displayName": "mdx-tsc",
  "version": "0.1.0",
  "private": true,
  "description": "Type-checking for MDX: frontmatter schemas, provided components, and type errors — powered by the mdx-tsc language server.",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "frontmatter",
    "mdx",
    "type-check",
    "typescript",
    "volar"
  ],
  "homepage": "https://github.com/hipstersmoothie/mdx-tsc/tree/main/editors/vscode#readme",
  "bugs": "https://github.com/hipstersmoothie/mdx-tsc/issues",
  "license": "MIT",
  "author": "Andrew Lisowski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hipstersmoothie/mdx-tsc.git",
    "directory": "editors/vscode"
  },
  "publisher": "hipstersmoothie",
  "main": "./dist/extension.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "build": "npm run typecheck && node esbuild.js",
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.82.0",
    "@volar/vscode": "~2.4.28",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "mdx-tsc": "workspace:*",
    "typescript": "^5.6.0",
    "vscode-languageclient": "^10.1.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "mdx",
        "aliases": [
          "MDX",
          "mdx"
        ],
        "extensions": [
          ".mdx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "mdx-tsc",
      "properties": {
        "mdx-tsc.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the mdx-tsc language server."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:mdx"
  ],
  "engines": {
    "vscode": "^1.82.0"
  }
}
