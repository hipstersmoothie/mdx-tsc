{
  "name": "mdx-ts-vscode",
  "displayName": "mdx-ts",
  "description": "Type-checking for MDX: frontmatter schemas, provided components, and parse errors — powered by the mdx-ts language server.",
  "version": "0.1.0",
  "publisher": "mdx-ts",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": ["onLanguage:mdx"],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mdx",
        "aliases": ["MDX", "mdx"],
        "extensions": [".mdx"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "mdx-ts",
      "properties": {
        "mdx-ts.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace the communication between VS Code and the mdx-ts language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ --watch"
  },
  "dependencies": {
    "@volar/vscode": "~2.4.28",
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.82.0",
    "typescript": "^5.6.0"
  }
}
