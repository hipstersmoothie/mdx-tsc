{
  "compilerOptions": {
    "target": "ES2022", "module": "preserve", "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"], "jsx": "react-jsx", "jsxImportSource": "react",
    "allowJs": true, "checkJs": true, "strict": true, "noEmit": true, "skipLibCheck": true, "types": []
  },
  "mdx": { "checkMdx": true },
  "include": ["**/*.mdx", "**/*.tsx"]
}
