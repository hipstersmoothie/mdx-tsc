{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": []
  },
  "mdx": {
    "checkMdx": true,
    "frontmatter": {
      "blog/**/*.mdx": "./schema.ts#BlogFrontmatter",
      "docs/**/*.mdx": "./schema.ts#DocFrontmatter"
    }
  },
  "include": ["**/*.mdx", "**/*.ts"]
}
